<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.compass.controller.LoginController"
      alignment="CENTER" spacing="16" styleClass="root">
    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>
    <Label text="Compass" styleClass="header-label"/>
    <Label text="Campus Complaint Management System" styleClass="subheader-label"/>
    <VBox styleClass="card" spacing="12" maxWidth="400">
        <Label text="Sign In"/>
        <TextField fx:id="usernameField" promptText="Username"/>
        <PasswordField fx:id="passwordField" promptText="Password"/>
        <Label fx:id="errorLabel" styleClass="error-label" visible="false" managed="false"/>
        <HBox spacing="10">
            <Button text="Login" onAction="#handleLogin" styleClass="primary-button" defaultButton="true"/>
            <Button text="Register" onAction="#handleRegister" styleClass="secondary-button"/>
        </HBox>
        <Label text="Demo: admin / Admin@123  |  student1 / Student@123" styleClass="subheader-label" wrapText="true"/>
    </VBox>
</VBox>
