<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.compass.controller.AdminDashboardController"
            styleClass="root">
    <top>
        <VBox spacing="12">
            <HBox spacing="12" styleClass="card">
                <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
                <Label text="Admin Dashboard" styleClass="header-label"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Button text="Campus Map" onAction="#handleOpenMap" styleClass="secondary-button"/>
                <Button text="Logout" onAction="#handleLogout" styleClass="danger-button"/>
            </HBox>
            <HBox spacing="12">
                <padding><Insets left="16" right="16"/></padding>
                <VBox styleClass="stat-box">
                    <Label text="Total" styleClass="subheader-label"/>
                    <Label fx:id="totalLabel" styleClass="stat-value"/>
                </VBox>
                <VBox styleClass="stat-box">
                    <Label text="Resolved" styleClass="subheader-label"/>
                    <Label fx:id="resolvedLabel" styleClass="stat-value"/>
                </VBox>
                <VBox styleClass="stat-box">
                    <Label text="Pending" styleClass="subheader-label"/>
                    <Label fx:id="pendingLabel" styleClass="stat-value"/>
                </VBox>
                <VBox styleClass="stat-box" HBox.hgrow="ALWAYS">
                    <Label text="Analytics" styleClass="subheader-label"/>
                    <Label fx:id="analyticsLabel" wrapText="true"/>
                </VBox>
            </HBox>
            <HBox spacing="10" styleClass="card">
                <padding><Insets top="8" right="16" bottom="8" left="16"/></padding>
                <ComboBox fx:id="deptFilter" promptText="Department" prefWidth="160"/>
                <ComboBox fx:id="statusFilter" promptText="Status" prefWidth="140"/>
                <ComboBox fx:id="priorityFilter" promptText="Priority" prefWidth="120"/>
                <Button text="Filter" onAction="#handleFilter" styleClass="primary-button"/>
                <Button text="Refresh" onAction="#handleRefresh" styleClass="secondary-button"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <VBox spacing="8" styleClass="card">
            <padding><Insets top="8" right="16" bottom="16" left="16"/></padding>
            <HBox spacing="10">
                <Label text="All Complaints" styleClass="header-label"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="assignDeptCombo" promptText="Assign to dept" prefWidth="180"/>
                <Button text="Under Review" onAction="#handleUnderReview" styleClass="secondary-button"/>
                <Button text="Assign" onAction="#handleAssign" styleClass="primary-button"/>
                <Button text="Mark Resolved" onAction="#handleResolve" styleClass="secondary-button"/>
            </HBox>
            <TableView fx:id="complaintsTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="idCol" text="ID" prefWidth="45"/>
                    <TableColumn fx:id="studentCol" text="Student" prefWidth="120"/>
                    <TableColumn fx:id="titleCol" text="Title" prefWidth="160"/>
                    <TableColumn fx:id="deptCol" text="Department" prefWidth="120"/>
                    <TableColumn fx:id="priorityCol" text="Priority" prefWidth="80"/>
                    <TableColumn fx:id="statusCol" text="Status" prefWidth="110"/>
                    <TableColumn fx:id="dateCol" text="Created" prefWidth="130"/>
                </columns>
            </TableView>
            <Label fx:id="statusMessage" styleClass="subheader-label"/>
        </VBox>
    </center>
</BorderPane>
