<plugin>
    <groupId>org.codehaus.mojo</groupId>
    <artifactId>exec-maven-plugin</artifactId>
    <version>3.1.0</version>
    <configuration>
        <mainClass>com.compass.CompassApplication</mainClass>
        <modulePaths>
            <modulePath>${env.PATH_TO_FX}</modulePath>
        </modulePaths>
    </configuration>
</plugin>