<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="rootPane" stylesheets="@../css/compass.css" xmlns="http://javafx.com/javafx/21.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.campus.controller.StudentDashboardController">
    <left>
        <VBox styleClass="sidebar" spacing="0">
            <VBox styleClass="user-info" spacing="5" style="-fx-padding: 15; -fx-border-color: #ddd; -fx-border-width: 0 0 1 0;">
                <Label fx:id="userLabel" styleClass="user-name" />
                <Label fx:id="userRoleLabel" styleClass="user-role" />
            </VBox>

            <VBox fx:id="sidebarContainer" spacing="10" style="-fx-padding: 15;" VBox.vgrow="ALWAYS" />

            <Button fx:id="logoutButton" text="Logout" styleClass="logout-btn" style="-fx-padding: 10px; -fx-margin: 10px;" />
        </VBox>
    </left>

    <!-- Main Content Area -->
    <center>
        <Pane fx:id="contentArea" styleClass="content-area" />
    </center>
</BorderPane>
