<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="rootPane" spacing="10" style="-fx-padding: 20;" xmlns="http://javafx.com/javafx/21.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.campus.controller.AdminComplaintController">
    <Label text="Manage Complaints" style="-fx-font-size: 20; -fx-font-weight: bold;" />

    <HBox spacing="10" style="-fx-padding: 10; -fx-border-color: #ddd; -fx-border-width: 0 0 1 0;">
        <TextField fx:id="searchField" promptText="Search complaints..." HBox.hgrow="ALWAYS" />
        <ComboBox fx:id="statusFilterCombo" prefWidth="120" />
        <ComboBox fx:id="priorityFilterCombo" prefWidth="120" />
        <Button fx:id="searchButton" text="Search" />
        <Button fx:id="refreshButton" text="Refresh" />
    </HBox>

    <HBox spacing="15" VBox.vgrow="ALWAYS">
        <VBox HBox.hgrow="ALWAYS">
            <TableView fx:id="complaintsTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="idColumn" text="ID" prefWidth="50" />
                    <TableColumn fx:id="titleColumn" text="Title" prefWidth="200" />
                    <TableColumn fx:id="statusColumn" text="Status" prefWidth="100" />
                    <TableColumn fx:id="priorityColumn" text="Priority" prefWidth="100" />
                    <TableColumn fx:id="studentColumn" text="Student ID" prefWidth="80" />
                </columns>
            </TableView>
        </VBox>

        <VBox fx:id="detailsPanel" style="-fx-border-color: #ddd; -fx-border-radius: 5; -fx-padding: 15;" prefWidth="300" spacing="10">
            <Label fx:id="complaintIdLabel" text="Select a complaint" style="-fx-font-weight: bold; -fx-font-size: 14;" />

            <Label text="Description:" style="-fx-font-weight: bold;" />
            <TextArea fx:id="descriptionArea" wrapText="true" prefRowCount="5" editable="false" />

            <Label text="Status:" style="-fx-font-weight: bold;" />
            <ComboBox fx:id="statusCombo" prefWidth="Double.MAX_VALUE" />

            <Label text="Priority:" style="-fx-font-weight: bold;" />
            <ComboBox fx:id="priorityCombo" prefWidth="Double.MAX_VALUE" />

            <Label text="Assign to Department:" style="-fx-font-weight: bold;" />
            <ComboBox fx:id="departmentCombo" prefWidth="Double.MAX_VALUE" />

            <HBox spacing="10">
                <Button fx:id="updateButton" text="Update" HBox.hgrow="ALWAYS" />
                <Button fx:id="assignButton" text="Assign" HBox.hgrow="ALWAYS" />
                <Button fx:id="deleteButton" text="Delete" style="-fx-text-fill: white; -fx-background-color: #f44336;" HBox.hgrow="ALWAYS" />
            </HBox>
        </VBox>
    </HBox>
</VBox>
