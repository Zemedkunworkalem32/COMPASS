<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.compass.controllers.AdminDashboardController"
            styleClass="root">
    <top>
        <VBox spacing="12">
            <HBox spacing="12" styleClass="card">
                <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
                <Label fx:id="headerLabel" text="Admin Dashboard" styleClass="header-label"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Button text="Campus Map" onAction="#handleOpenMap" styleClass="secondary-button"/>
                <Button text="Logout" onAction="#handleLogout" styleClass="danger-button"/>
            </HBox>

            <HBox spacing="12">
                <padding><Insets left="16" right="16"/></padding>
                <VBox styleClass="stat-box">
                    <Label text="Total" styleClass="subheader-label"/>
                    <Label fx:id="totalLabel" styleClass="stat-value"/>
                </VBox>
                <VBox styleClass="stat-box">
                    <Label text="Pending" styleClass="subheader-label"/>
                    <Label fx:id="pendingLabel" styleClass="stat-value"/>
                </VBox>
                <VBox styleClass="stat-box">
                    <Label text="In Progress" styleClass="subheader-label"/>
                    <Label fx:id="inProgressLabel" styleClass="stat-value"/>
                </VBox>
                <VBox styleClass="stat-box">
                    <Label text="Resolved" styleClass="subheader-label"/>
                    <Label fx:id="resolvedLabel" styleClass="stat-value"/>
                </VBox>
                <VBox styleClass="stat-box" HBox.hgrow="ALWAYS">
                    <Label text="Complaints by Category" styleClass="subheader-label"/>
                    <Label fx:id="categoryAnalyticsLabel" wrapText="true"/>
                </VBox>
            </HBox>
        </VBox>
    </top>

    <center>
        <TabPane>
            <tabs>
                <Tab text="Complaints" closable="false">
                    <VBox spacing="10" styleClass="card">
                        <padding><Insets top="12" right="16" bottom="16" left="16"/></padding>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <ComboBox fx:id="categoryFilter" promptText="Category" prefWidth="150"/>
                            <ComboBox fx:id="statusFilter" promptText="Status" prefWidth="150"/>
                            <Button text="Filter" onAction="#handleFilter" styleClass="primary-button"/>
                            <Button text="Refresh" onAction="#handleRefresh" styleClass="secondary-button"/>
                            <Pane HBox.hgrow="ALWAYS"/>
                            <Button text="View Details" onAction="#handleViewDetails" styleClass="secondary-button"/>
                        </HBox>

                        <TableView fx:id="complaintsTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="idCol" text="ID" prefWidth="50"/>
                                <TableColumn fx:id="studentCol" text="Student" prefWidth="140"/>
                                <TableColumn fx:id="titleCol" text="Title" prefWidth="230"/>
                                <TableColumn fx:id="categoryCol" text="Category" prefWidth="100"/>
                                <TableColumn fx:id="statusCol" text="Status" prefWidth="120"/>
                                <TableColumn fx:id="noteCol" text="Admin Notes" prefWidth="230"/>
                                <TableColumn fx:id="dateCol" text="Created" prefWidth="160"/>
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>
                        </TableView>

                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="Status:"/>
                            <ComboBox fx:id="statusCombo" prefWidth="150"/>
                            <Button text="Update" onAction="#handleUpdateComplaint" styleClass="primary-button"/>
                            <Button text="Resolve" onAction="#handleResolveComplaint" styleClass="success-button"/>
                        </HBox>
                        <TextArea fx:id="adminNoteArea" promptText="Admin notes visible to the student..." prefRowCount="3"/>
                    </VBox>
                </Tab>

                <Tab fx:id="systemAdminTab" text="System Admin" closable="false">
                    <VBox spacing="12" styleClass="card">
                        <padding><Insets top="12" right="16" bottom="16" left="16"/></padding>
                        <Label text="Manage Admin Accounts" styleClass="header-label"/>
                        <HBox spacing="8">
                            <TextField fx:id="adminNameField" promptText="Full name"/>
                            <TextField fx:id="adminUsernameField" promptText="Username"/>
                            <TextField fx:id="adminEmailField" promptText="Email"/>
                            <PasswordField fx:id="adminPasswordField" promptText="Password"/>
                            <Button text="Add Admin" onAction="#handleAddAdmin" styleClass="primary-button"/>
                            <Button text="Remove Selected" onAction="#handleRemoveAdmin" styleClass="danger-button"/>
                        </HBox>
                        <TableView fx:id="adminsTable" prefHeight="150">
                            <columns>
                                <TableColumn fx:id="adminIdCol" text="ID" prefWidth="60"/>
                                <TableColumn fx:id="adminFullNameCol" text="Name" prefWidth="180"/>
                                <TableColumn fx:id="adminUsernameCol" text="Username" prefWidth="160"/>
                                <TableColumn fx:id="adminEmailCol" text="Email" prefWidth="220"/>
                            </columns>
                        </TableView>

                        <Separator/>
                        <Label text="Students" styleClass="header-label"/>
                        <HBox spacing="8">
                            <TextField fx:id="studentSearchField" promptText="Search students by name, username, or email" HBox.hgrow="ALWAYS"/>
                            <Button text="Search" onAction="#handleSearchStudents" styleClass="primary-button"/>
                        </HBox>
                        <TableView fx:id="studentsTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="studentIdCol" text="ID" prefWidth="60"/>
                                <TableColumn fx:id="studentNameCol" text="Name" prefWidth="220"/>
                                <TableColumn fx:id="studentUsernameCol" text="Username" prefWidth="180"/>
                                <TableColumn fx:id="studentEmailCol" text="Email" prefWidth="260"/>
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>
                        </TableView>
                    </VBox>
                </Tab>
            </tabs>
        </TabPane>
    </center>

    <bottom>
        <Label fx:id="statusMessage" styleClass="subheader-label" wrapText="true">
            <padding><Insets top="8" right="16" bottom="8" left="16"/></padding>
        </Label>
    </bottom>
</BorderPane>
