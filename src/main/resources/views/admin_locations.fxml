<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="rootPane" spacing="10" style="-fx-padding: 20;" xmlns="http://javafx.com/javafx/21.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.campus.controller.AdminLocationController">
    <Label text="Manage Locations" style="-fx-font-size: 20; -fx-font-weight: bold;" />

    <HBox spacing="10" style="-fx-padding: 10; -fx-border-color: #ddd; -fx-border-width: 0 0 1 0;">
        <TextField fx:id="searchField" promptText="Search locations..." HBox.hgrow="ALWAYS" />
        <Button fx:id="searchButton" text="Search" />
        <Button fx:id="refreshButton" text="Refresh" />
        <Button fx:id="addButton" text="Add Location" style="-fx-padding: 8px 15px;" />
    </HBox>

    <HBox spacing="15" VBox.vgrow="ALWAYS">
        <VBox HBox.hgrow="ALWAYS">
            <TableView fx:id="locationsTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="idColumn" text="ID" prefWidth="50" />
                    <TableColumn fx:id="nameColumn" text="Name" prefWidth="150" />
                    <TableColumn fx:id="buildingColumn" text="Building" prefWidth="150" />
                    <TableColumn fx:id="floorColumn" text="Floor" prefWidth="100" />
                </columns>
            </TableView>
        </VBox>

        <VBox fx:id="detailsPanel" style="-fx-border-color: #ddd; -fx-border-radius: 5; -fx-padding: 15;" prefWidth="300" spacing="10">
            <Label text="Location Details" style="-fx-font-weight: bold; -fx-font-size: 14;" />

            <Label text="Name:" style="-fx-font-weight: bold;" />
            <TextField fx:id="nameField" />

            <Label text="Building:" style="-fx-font-weight: bold;" />
            <TextField fx:id="buildingField" />

            <Label text="Floor:" style="-fx-font-weight: bold;" />
            <TextField fx:id="floorField" />

            <HBox spacing="10">
                <Button fx:id="updateButton" text="Update" HBox.hgrow="ALWAYS" />
                <Button fx:id="deleteButton" text="Delete" style="-fx-text-fill: white; -fx-background-color: #f44336;" HBox.hgrow="ALWAYS" />
            </HBox>
        </VBox>
    </HBox>
</VBox>
