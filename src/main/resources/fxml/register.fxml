<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.compass.controller.RegisterController"
      alignment="CENTER" spacing="16" styleClass="root">
    <padding>
        <Insets top="30" right="40" bottom="30" left="40"/>
    </padding>
    <Label text="Student Registration" styleClass="header-label"/>
    <VBox styleClass="card" spacing="10" maxWidth="420">
        <TextField fx:id="fullNameField" promptText="Full Name"/>
        <TextField fx:id="usernameField" promptText="Username"/>
        <TextField fx:id="emailField" promptText="Email"/>
        <PasswordField fx:id="passwordField" promptText="Password"/>
        <PasswordField fx:id="confirmPasswordField" promptText="Confirm Password"/>
        <Label fx:id="errorLabel" styleClass="error-label" visible="false" managed="false"/>
        <HBox spacing="10">
            <Button text="Register" onAction="#handleRegister" styleClass="primary-button"/>
            <Button text="Back to Login" onAction="#handleBack" styleClass="secondary-button"/>
        </HBox>
    </VBox>
</VBox>
