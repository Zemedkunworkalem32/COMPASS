<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.compass.controller.StudentDashboardController"
            styleClass="root">
    <top>
        <HBox spacing="12" styleClass="card">
            <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
            <VBox>
                <Label text="Student Dashboard" styleClass="header-label"/>
                <Label fx:id="welcomeLabel" styleClass="subheader-label"/>
            </VBox>
            <Pane HBox.hgrow="ALWAYS"/>
            <Button text="Submit Complaint" onAction="#handleSubmitComplaint" styleClass="primary-button"/>
            <Button text="Campus Map" onAction="#handleOpenMap" styleClass="secondary-button"/>
            <Button text="Logout" onAction="#handleLogout" styleClass="danger-button"/>
        </HBox>
    </top>
    <center>
        <VBox spacing="8" styleClass="card">
            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
            <Label text="My Complaints" styleClass="header-label"/>
            <TableView fx:id="complaintsTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="idCol" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="titleCol" text="Title" prefWidth="180"/>
                    <TableColumn fx:id="deptCol" text="Department" prefWidth="140"/>
                    <TableColumn fx:id="priorityCol" text="Priority" prefWidth="90"/>
                    <TableColumn fx:id="statusCol" text="Status" prefWidth="120"/>
                    <TableColumn fx:id="dateCol" text="Submitted" prefWidth="150"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
